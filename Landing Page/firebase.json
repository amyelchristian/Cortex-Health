{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**/*.html",
                "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
            },
            {
                "source": "**/*.js",
                "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
            },
            {
                "source": "**/*.css",
                "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
            }
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "functions": [
        {
            "source": "functions",
            "codebase": "default",
            "ignore": [
                "node_modules",
                ".git",
                "firebase-debug.log",
                "firebase-debug.*.log",
                "*.local"
            ]
        }
    ],
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    }
}